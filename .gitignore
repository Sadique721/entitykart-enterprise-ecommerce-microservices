# ─────────────────────────────────────────────────────────────────────────────
# EntityKart – .gitignore
# Updated 2026-06-26: Added obsolete service directories + junk files
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment configurations ────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── IDE / Editors ─────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
out/

# ── Gradle / Java / Maven build artifacts ─────────────────────────────────────
.gradle/
**/build/
target/
*.class
.project
.classpath
.settings/
build/
bin/
gradle.properties

# ── Flutter / Dart ────────────────────────────────────────────────────────────
.dart_tool/
.packages
.pub-cache/
.pub/

# ── Android ───────────────────────────────────────────────────────────────────
*.idsig
local.properties
android/.gradle/
android/app/build/

# ── Obsolete / Merged service directories ─────────────────────────────────────
# These 4 services were merged into common-services/ on 2026-06-26
api-gateway/
discovery-server/
notification-service/
common-service/

# ── Debug / Test scripts (local only, never commit) ───────────────────────────
brute_force_aiven.py
test_db.py
test_user_service.ps1
poll.bat
poll_api.bat
poll_logs.bat
poll_new_deploy.bat
test_extract/

# ── OS files ──────────────────────────────────────────────────────────────────
Thumbs.db
Ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
